# =============================================================================
# CloudDeploy — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://admin:clouddeploy_secret@localhost:27017/clouddeploy?authSource=admin

# Redis (BullMQ Job Queue)
REDIS_URL=redis://:clouddeploy_redis_secret@localhost:6379

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for env variable secrets)
ENCRYPTION_KEY=your_32_char_encryption_key_here!!

# Docker Registry
# Options: dockerhub | ecr | harbor
DOCKER_REGISTRY=dockerhub
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PASSWORD=your_dockerhub_password_or_token
# For ECR: AWS_REGION=us-east-1, AWS_ACCESS_KEY_ID=..., AWS_SECRET_ACCESS_KEY=...
# For Harbor: HARBOR_URL=https://registry.example.com

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# Kubernetes
# 'incluster' = running inside K8s cluster (production)
# 'kubeconfig' = use ~/.kube/config (local dev with minikube/kind)
K8S_CONFIG=kubeconfig
K8S_KUBECONFIG_PATH=~/.kube/config
# Prefix for all K8s namespaces created by CloudDeploy
KUBERNETES_NAMESPACE_PREFIX=clouddeploy

# Public Domain (for generating app URLs)
# Local dev: use minikube IP or nip.io
# Production: your actual domain
BASE_DOMAIN=clouddeploy.local
# Ingress class name (nginx | traefik)
INGRESS_CLASS=nginx

# Repository Storage (where GitHub repos are cloned)
REPOS_PATH=./repos

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="CloudDeploy <noreply@clouddeploy.com>"

# Notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# Prometheus (for metrics — optional, enable when Prometheus is running)
PROMETHEUS_URL=http://prometheus:9090

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin (first user with this email gets admin role automatically)
ADMIN_EMAIL=admin@clouddeploy.com

# Logging
LOG_LEVEL=debug
